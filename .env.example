# ====== 闲鱼 Cookie ======
# 方式1（推荐）：从浏览器复制完整 Cookie 字符串
# 打开 https://www.goofish.pro 登录后，F12 -> Network -> 任意请求 -> Headers -> Cookie
GOOFISH_COOKIE=

# 方式2：分别填写各 Cookie 字段（如不使用 GOOFISH_COOKIE 则用这些）
UNB=
CNA=
MH5_TK=
TRACKNICK=

# ====== DeepSeek API ======
DEEPSEEK_API_KEY=

# ====== 运行参数 ======
# 回复冷却时间（毫秒）
REPLY_COOLDOWN=60000
# 日志目录
LOG_DIR=./logs
# 管理接口端口（默认8720）
ADMIN_PORT=8720
# 管理接口鉴权密钥（强烈建议设置！设置后需要 Authorization: Bearer <密钥> 才能访问）
ADMIN_TOKEN=
# 管理接口 CORS 允许的源（默认 http://localhost）
ADMIN_CORS_ORIGIN=http://localhost
